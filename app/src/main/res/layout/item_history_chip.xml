<?xml version="1.0" encoding="utf-8"?>
<!--
    item_history_chip.xml
    Single chip dalam horizontal RecyclerView di TranslateFragment.
    Source text 1 baris, result 1 baris, selebihnya (...) — persis Yandex.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="200dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurfaceVariant">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Source text — 1 baris, ellipsize end -->
        <TextView
            android:id="@+id/tvHistorySource"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="?attr/colorOnSurface"
            tools:text="Hello, good day? can i help you?" />

        <!-- Translated text — 1 baris, ellipsize end -->
        <TextView
            android:id="@+id/tvHistoryResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:alpha="0.7"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="?attr/colorOnSurface"
            tools:text="Halo, selamat siang? bisa saya bantu?" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>