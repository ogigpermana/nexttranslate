<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_dialog_mode.xml
    Two-way interpreter / conversation mode screen — Yandex-style layout.

    Layout structure:
      - Root LinearLayout receives top inset via ViewCompat in DialogModeFragment.
      - Toolbar: title only, no back button (tab-based navigation)
      - Conversation log: fills remaining space, scrollable chat bubbles
      - Bottom controls: 2 mic buttons side by side + 2 language selectors
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootDialog"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarDialog"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:title="@string/title_dialog_mode"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.2" />

    <!-- Conversation log — fills remaining space -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="?attr/colorSurface">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerConversation"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false" />

        <LinearLayout
            android:id="@+id/layoutEmptyDialog"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="32dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_mic"
                android:alpha="0.25"
                android:contentDescription="@null" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Tap the mic to start talking"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.6"
                android:gravity="center" />

        </LinearLayout>

    </FrameLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutline"
        android:alpha="0.2" />

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/colorSurfaceVariant"
        android:paddingTop="16dp"
        android:paddingBottom="80dp"
        android:paddingHorizontal="24dp">

        <!-- 2 mic buttons side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="12dp">

            <!-- Mic User A -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabMicA"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="@null"
                    app:fabSize="normal"
                    app:backgroundTint="?attr/colorPrimary"
                    app:tint="?attr/colorOnPrimary" />

            </LinearLayout>

            <!-- Divider vertical -->
            <View
                android:layout_width="1dp"
                android:layout_height="56dp"
                android:background="?attr/colorOutline"
                android:alpha="0.3"
                android:layout_marginHorizontal="8dp" />

            <!-- Mic User B -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">

                <com.google.android.material.floatingactionbutton.FloatingActionButton
                    android:id="@+id/fabMicB"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@drawable/ic_mic"
                    android:contentDescription="@null"
                    app:fabSize="normal"
                    app:backgroundTint="?attr/colorSecondary"
                    app:tint="?attr/colorOnSecondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- 2 language selectors side by side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
			android:layout_marginBottom="90dp"
            android:gravity="center">

            <!-- Lang selector User A -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLangA"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/lang_indonesian"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="?attr/colorPrimary"
                app:icon="@drawable/ic_arrow_down"
                app:iconGravity="textEnd"
                app:iconSize="16dp" />

            <!-- Lang selector User B -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLangB"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/lang_english"
                android:textSize="12sp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="?attr/colorSecondary"
                app:icon="@drawable/ic_arrow_down"
                app:iconGravity="textEnd"
                app:iconSize="16dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
