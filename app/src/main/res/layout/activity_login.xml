<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_login.xml
    Login screen — Google SSO only.

    Layout structure:
      - App logo + name + tagline (top)
      - Google Sign-In button (primary action)
      - Continue as Guest text button (secondary)
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp"
        android:minHeight="@dimen/min_screen_height">

        <!-- App logo -->
        <ImageView
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:src="@mipmap/ic_launcher"
            android:contentDescription="@null"
            android:layout_marginBottom="16dp" />

        <!-- App name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceHeadlineMedium"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Tagline -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_tagline"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:alpha="0.6"
            android:gravity="center"
            android:layout_marginBottom="56dp" />

        <!-- Google Sign-In button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_google"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/login_btn_google"
            android:textSize="15sp"
            style="@style/Widget.Material3.Button.OutlinedButton"
            app:icon="@drawable/ic_google"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            android:layout_marginBottom="16dp" />

        <!-- Continue as guest -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guest"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_btn_guest"
            style="@style/Widget.Material3.Button.TextButton"
            android:alpha="0.7" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
