<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_main.xml
    Root layout for MainActivity.

    Design decision:
      MainActivity does NOT own a toolbar. Each Fragment manages its own
      toolbar independently. This prevents the double-toolbar issue where
      both MainActivity's AppBar and TranslateFragment's toolbar were visible.

    Structure:
      - FrameLayout      : full-screen fragment container (edge-to-edge)
      - BottomNavigationView : pinned to bottom, keyboard-aware via WindowInsets

    Keyboard behaviour:
      windowSoftInputMode = adjustResize (in Manifest).
      BottomNavigationView uses android:fitsSystemWindows="false" so it stays
      pinned to the bottom and does NOT get pushed up by the soft keyboard.
      Each Fragment handles its own inset padding for content scrolling.

    Navigation:
      Fragment swaps are managed by MainActivity.switchTab() and openFragment().
      TranslateFragment owns the top toolbar (collection icon + title + avatar).
      Other fragments own their own toolbar (back arrow + title).
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false">

    <!--
        Full-screen fragment container.
        No AppBarLayout here — each Fragment manages its own toolbar.
        Fragments handle their own top/bottom inset padding.
    -->
    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!--
        BottomNavigationView — pinned to bottom of screen.
        fitsSystemWindows="false" prevents keyboard from pushing it up.
        WindowInsets for nav bar height handled in MainActivity.initViews().
    -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:fitsSystemWindows="false"
        app:menu="@menu/bottom_nav_menu"
        app:labelVisibilityMode="labeled" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>