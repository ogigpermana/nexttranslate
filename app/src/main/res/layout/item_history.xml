<?xml version="1.0" encoding="utf-8"?>
<!--
    item_history.xml
    Layout for a single translation history entry — Gmail inbox style.

    Design:
      - No card elevation or per-item rounded corners; the list container
        (fragment_history.xml) wraps all items in one rounded surface.
      - Top/bottom rounded corners are applied programmatically in
        HistoryAdapter.onBindViewHolder() using ShapeableImageView background
        on the root, based on item position (first / last / middle).
      - Divider line between items is drawn by the RecyclerView DividerItemDecoration
        added in HistoryFragment — NOT a View inside this layout.

    View ID contract (referenced by HistoryAdapter.java):
      - textViewSourceText     : Original source text (bold)
      - textViewTranslatedText : Translated result (primary colour, 1 line)
      - textViewLanguagePair   : Language pair label e.g. "EN → ID"
      - textViewTimestamp      : Relative time e.g. "2 hours ago"

    Tap on root view triggers onItemClick() to reuse the translation.
    Swipe left or right triggers delete via ItemTouchHelper in HistoryFragment.
    Delete icon removed — swipe is the sole delete gesture.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootItemHistory"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer"
    android:paddingTop="0dp"
    android:paddingBottom="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">
		
	<LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

         <!-- ======================================================
         Top row: language pair + timestamp
         ====================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <!--
                Language pair label e.g. "EN → ID"
                Shown in primary colour, small caps style.
            -->
            <TextView
                android:id="@+id/textViewLanguagePair"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorPrimary"
                android:letterSpacing="0.05"
                tools:text="EN → ID" />
    
            <!--
                Relative timestamp e.g. "2 jam lalu"
                Formatted in HistoryAdapter.bind() using DateUtils.getRelativeTimeSpanString().
            -->
            <TextView
                android:id="@+id/textViewTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.7"
                tools:text="2 jam lalu" />

        </LinearLayout>

        <!-- ======================================================
             Source text — bold, max 2 lines
             ====================================================== -->
        <TextView
            android:id="@+id/textViewSourceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            tools:text="Hello, how are you?" />

        <!-- ======================================================
             Translated text — primary colour, 1 line
             ====================================================== -->
        <TextView
            android:id="@+id/textViewTranslatedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorPrimary"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Halo, apa kabar?" />

    </LinearLayout>
		
    <View
        android:id="@+id/viewDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="?attr/colorOutlineVariant" />
</LinearLayout>