<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_language.xml
    Language Manager screen — accessible via Settings > Download Language Packs.

    Layout structure:
      - Root LinearLayout receives top inset (status bar) via
        ViewCompat.setOnApplyWindowInsetsListener in LanguageFragment.
      - MaterialToolbar: back navigation + "Language Manager" title.
      - RecyclerView: paddingBottom="80dp" clears the bottom navigation bar.
      - Full-screen loading indicator: shown only during initial list load.

    View ID contract (referenced by LanguageFragment.java):
      - toolbar               : Back navigation + title
      - recyclerViewLanguages : List of all supported languages with download status
      - progressBarLanguage   : Full-screen loading indicator on initial list load
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLanguage"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    tools:context=".presentation.language.LanguageFragment">

    <!-- Toolbar: back navigation + title -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/cd_navigate_back"
        app:title="@string/title_language_manager"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <!-- Loading indicator — shown during initial list load -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="gone">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBarLanguage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:indeterminate="true" />

        <TextView
            android:id="@+id/textViewLoadingLanguages"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/loading_languages"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

    </LinearLayout>

    <!--
        Language list.
        paddingBottom="80dp" : clears the bottom navigation bar.
        clipToPadding="false" : last item scrolls under the padding area.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewLanguages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_language"
        tools:itemCount="8" />

</LinearLayout>
