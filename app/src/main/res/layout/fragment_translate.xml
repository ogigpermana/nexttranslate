<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_translate.xml
    Layout for the main translation screen (TranslateFragment).

    View ID contract (referenced by TranslateFragment.java):
      - editTextSourceInput       : Source text input
      - buttonSourceLanguage      : Source language selector button
      - buttonSwapLanguage        : Swap source/target language button
      - buttonTargetLanguage      : Target language selector button
      - buttonTranslate           : Trigger translation button
      - progressBarTranslate      : Loading indicator during translation
      - textViewTranslationResult : Displays the translated text
      - buttonCopyResult          : Copy result to clipboard
      - buttonAddFavorite         : Add result to favorites
-->
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    tools:context=".presentation.translate.TranslateFragment">

    <!-- Top App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="?attr/colorSurface"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/app_name"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="16dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Language Selector Row -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Source Language Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSourceLanguage"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="EN"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurface" />

                    <!-- Swap Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonSwapLanguage"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        app:icon="@drawable/ic_swap_horiz"
                        app:iconTint="?attr/colorPrimary"
                        app:iconSize="24dp" />

                    <!-- Target Language Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/buttonTargetLanguage"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="ID"
                        android:textAppearance="@style/TextAppearance.Material3.LabelLarge"
                        android:textColor="?attr/colorOnSurface" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Source Input Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">

                    <!-- Source Text Input -->
                    <EditText
                        android:id="@+id/editTextSourceInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="120dp"
                        android:padding="12dp"
                        android:gravity="top|start"
                        android:hint="@string/hint_enter_text"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:background="@null"
                        android:inputType="textMultiLine|textCapSentences"
                        android:scrollbars="vertical"
                        tools:text="Hello, how are you?" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="?attr/colorOutlineVariant" />

                    <!-- Translate Button row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:padding="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTranslate"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Clear"
                            app:icon="@drawable/ic_close" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Translation Result Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="0dp"
                app:cardCornerRadius="12dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                app:cardBackgroundColor="?attr/colorSecondaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="4dp">
					
					<!-- Shimmer placeholder — visible during translation -->
                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerTranslate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="12dp"
                        android:minHeight="120dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="16dp"
                                android:layout_marginBottom="10dp"
                                android:background="@drawable/shimmer_line" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="16dp"
                                android:orientation="horizontal"
                                android:layout_marginBottom="10dp">
                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="8"
                                    android:background="@drawable/shimmer_line" />
                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="2" />
                            </LinearLayout>

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="16dp"
                                android:orientation="horizontal">
                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="6"
                                    android:background="@drawable/shimmer_line" />
                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="4" />
                             </LinearLayout>

                        </LinearLayout>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <!-- Result Text -->
                    <TextView
                        android:id="@+id/textViewTranslationResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="120dp"
                        android:padding="12dp"
                        android:gravity="top|start"
                        android:hint="@string/hint_translation_result"
                        android:textAppearance="@style/TextAppearance.Material3.BodyLarge"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:textIsSelectable="true"
                        tools:text="Halo, apa kabar?" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginHorizontal="12dp"
                        android:background="?attr/colorOutline" />

                    <!-- Action buttons row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="end"
                        android:padding="4dp">

                        <!-- Copy Result Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonCopyResult"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:contentDescription="@string/cd_copy_result"
                            app:icon="@drawable/ic_content_copy"
                            app:iconTint="?attr/colorOnSecondaryContainer" />

                        <!-- Add to Favorite Button -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAddFavorite"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:contentDescription="@string/cd_add_favorite"
                            app:icon="@drawable/ic_bookmark_border"
                            app:iconTint="?attr/colorOnSecondaryContainer" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>