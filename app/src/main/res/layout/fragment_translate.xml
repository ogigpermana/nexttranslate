<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:background="?attr/colorSurface">

    <!-- Toolbar — fitsSystemWindows=true pada root agar tidak overlap statusbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarTranslate"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface">

        <ImageButton
            android:id="@+id/btnCollection"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start|center_vertical"
            android:layout_marginStart="4dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_collection"
            android:src="@drawable/ic_collection"
            android:padding="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/app_name"
            android:textAppearance="?attr/textAppearanceTitleLarge"
            android:textColor="?attr/colorOnSurface" />

        <ImageButton
            android:id="@+id/btnAvatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_avatar_circle"
            android:contentDescription="@string/cd_avatar"
            android:src="@drawable/ic_person"
            android:scaleType="centerCrop" />

    </com.google.android.material.appbar.MaterialToolbar>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="?attr/colorSurface">

            <!-- Translate card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTranslate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="12dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Language bar -->
                    <FrameLayout
                        android:id="@+id/layoutLanguageBar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonSourceLanguage"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="EN"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/buttonTargetLanguage"
                                style="@style/Widget.Material3.Button.TextButton"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:text="ID"
                                android:textAppearance="?attr/textAppearanceLabelLarge"
                                android:textColor="?attr/colorOnSurface" />

                        </LinearLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonSwapLanguage"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:layout_gravity="center"
                            app:icon="@drawable/ic_swap_horiz"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="18dp" />

                    </FrameLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutlineVariant"
                        android:alpha="0.5" />

                    <!-- Input — vertical scroll internal -->
                    <EditText
                        android:id="@+id/editTextSourceInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="160dp"
                        android:maxHeight="200dp"
                        android:padding="16dp"
                        android:gravity="top|start"
                        android:hint="@string/hint_enter_text"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        android:textSize="20sp"
                        android:background="@null"
                        android:inputType="textMultiLine|textCapSentences"
                        android:scrollbars="vertical"
                        android:overScrollMode="always"
                        android:nestedScrollingEnabled="true"
                        tools:text="Hello" />

                    <!-- Input action bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonPaste"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_paste"
                            app:icon="@drawable/ic_clipboard"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="20dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipTranslateMode"
                            style="@style/Widget.Material3.Chip.Assist"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2dp"
                            android:text="@string/mode_fast"
                            app:chipBackgroundColor="?attr/colorSurfaceContainerHigh"
                            app:chipIcon="@drawable/ic_arrow_down"
                            app:chipIconTint="?attr/colorOnSurfaceVariant"
                            app:chipIconSize="18dp"
                            app:iconEndPadding="4dp"
                            app:ensureMinTouchTargetSize="false" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonCamera"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_camera"
                            app:icon="@drawable/ic_camera"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonMic"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_mic"
                            app:icon="@drawable/ic_mic"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonClear"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_clear"
                            android:visibility="gone"
                            app:icon="@drawable/ic_close"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                    </LinearLayout>

                    <View
                        android:id="@+id/dividerInputResult"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="?attr/colorOutline"
                        android:alpha="0.3"
                        android:visibility="gone" />

                    <!-- Shimmer -->
                    <com.facebook.shimmer.ShimmerFrameLayout
                        android:id="@+id/shimmerTranslate"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="16dp"
                        android:minHeight="80dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <View
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:layout_marginBottom="12dp"
                                android:background="@drawable/shimmer_line" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="20dp"
                                android:orientation="horizontal">

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="7"
                                    android:background="@drawable/shimmer_line" />

                                <View
                                    android:layout_width="0dp"
                                    android:layout_height="match_parent"
                                    android:layout_weight="3" />

                            </LinearLayout>

                        </LinearLayout>

                    </com.facebook.shimmer.ShimmerFrameLayout>

                    <!-- Result — 1 line, for the rest (...) -->
                    <TextView
                        android:id="@+id/textViewTranslationResult"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="80dp"
                        android:maxHeight="300dp"
                        android:paddingHorizontal="16dp"
                        android:paddingTop="16dp"
                        android:paddingBottom="4dp"
                        android:gravity="top|start"
                        android:hint="@string/hint_translation_result"
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textIsSelectable="true"
                        android:scrollbars="vertical"
                        android:overScrollMode="always"
                        android:nestedScrollingEnabled="true"
                        android:visibility="gone"
                        tools:text="Halo"
                        tools:visibility="visible" />

                    <!-- Result action bar -->
                    <LinearLayout
                        android:id="@+id/layoutResultActions"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="4dp"
                        android:visibility="gone">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonTtsResult"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_tts_result"
                            app:icon="@drawable/ic_volume_up"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonCopyResult"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_copy_result"
                            app:icon="@drawable/ic_content_copy"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonAddFavorite"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_add_favorite"
                            app:icon="@drawable/ic_bookmark_border"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />
							
						<!--
                            Save to Collection button.
                            Tap opens a BottomSheetDialog listing the user's collections.
                        -->
                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonSaveToCollection"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="Save to collection"
                            app:icon="@drawable/ic_collection"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/buttonMoreResult"
                            style="@style/Widget.Material3.Button.IconButton"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:contentDescription="@string/cd_more"
                            app:icon="@drawable/ic_more_vert"
                            app:iconTint="?attr/colorOnSurfaceVariant"
                            app:iconSize="22dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!--
                History section.
                Default GONE — hanya VISIBLE jika ada history item.
                Diatur dari Fragment di observer historyListLiveData.
            -->
            <LinearLayout
                android:id="@+id/layoutHistorySection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="20dp"
                android:paddingBottom="8dp"
                android:visibility="gone">

                <!-- Label "Riwayat" -->
                <TextView
                    android:id="@+id/buttonOpenHistory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:layout_marginBottom="8dp"
                    android:text="@string/label_history"
                    android:textAppearance="?attr/textAppearanceTitleMedium"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:background="?attr/selectableItemBackground" />

                <!--
                    Row: chip RecyclerView (scroll horizontal, weight=1)
                         + ic_history icon di ujung kanan (tidak ikut scroll).
                    Persis seperti Yandex Translate.
                -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerHistory"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                        tools:listitem="@layout/item_history_chip" />

                    <!-- Icon history — sejajar chip, tap → HistoryFragment -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnHistoryIcon"
                        style="@style/Widget.Material3.Button.IconButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="8dp"
                        android:contentDescription="@string/cd_history"
                        app:icon="@drawable/ic_history"
                        app:iconTint="?attr/colorOnSurfaceVariant"
                        app:iconSize="24dp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

</LinearLayout>
