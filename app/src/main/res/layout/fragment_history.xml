<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_history.xml
    Translation history screen.

    Layout structure:
      - Root LinearLayout receives top inset (status bar) via
        ViewCompat.setOnApplyWindowInsetsListener in HistoryFragment,
        so the toolbar sits correctly below the status bar on all API levels.
      - MaterialToolbar: back navigation (left) + clear-all menu (right).
      - Empty state: centred icon + label, shown when history list is empty.
      - RecyclerView: paddingBottom="80dp" keeps the last item above the
        bottom navigation bar; clipToPadding="false" allows overscroll.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootHistory"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface">

    <!--
        Toolbar
        navigationIcon  : back arrow — wired in HistoryFragment.initListeners()
        menu            : menu_history (clear-all action)
    -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/cd_back"
        app:title="@string/title_history"
        app:titleTextColor="?attr/colorOnSurface"
        app:menu="@menu/menu_history" />

    <!--
        Empty state
        Visibility toggled by HistoryFragment: VISIBLE when list is empty,
        GONE when the RecyclerView has items.
    -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_history"
            android:alpha="0.3"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/empty_history"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:alpha="0.5"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

    <!--
        History list
        paddingBottom="80dp"   : clears the bottom navigation bar so the
                                 last card is fully visible.
        clipToPadding="false"  : list items scroll under the padding area
                                 (overscroll effect).
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewHistory"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="140dp"
        android:clipToPadding="false"
        android:visibility="gone"
        tools:listitem="@layout/item_history"
        tools:visibility="visible" />

</LinearLayout>