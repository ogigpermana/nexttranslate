<?xml version="1.0" encoding="utf-8"?>
<!--
    item_favorite.xml
    Layout for a single favorite translation entry in the RecyclerView
    (used by FavoriteAdapter.FavoriteViewHolder).

    View ID contract (referenced by FavoriteAdapter.java):
      - textViewSourceText     : Original source text
      - textViewTranslatedText : Translated result text
      - textViewLanguagePair   : Language pair label e.g. "EN → ID"
      - imageViewDelete        : Delete icon button — triggers onDeleteClick()

    Tap on root view triggers onItemClick() to reuse the translation.

    Note: Structurally identical to item_history.xml but uses
    colorTertiaryContainer as background to visually distinguish
    favorite entries from history entries.
-->
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardElevation="0dp"
    app:cardCornerRadius="12dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:cardBackgroundColor="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ======================================================
             Top row: language pair label + delete button
             ====================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <!-- Language pair e.g. "EN → ID" -->
            <TextView
                android:id="@+id/textViewLanguagePair"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorTertiary"
                android:letterSpacing="0.05"
                tools:text="EN → ID" />

            <!-- Bookmark filled icon — visual indicator this is a favorite -->
            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginEnd="8dp"
                app:tint="?attr/colorTertiary"
                android:contentDescription="@null" />

            <!-- Delete icon button -->
            <ImageView
                android:id="@+id/imageViewDelete"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_delete_outline"
                android:contentDescription="@string/cd_delete_favorite_item"
                app:tint="?attr/colorOnSurfaceVariant"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ======================================================
             Source text
             ====================================================== -->
        <TextView
            android:id="@+id/textViewSourceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            tools:text="Hello, how are you?" />

        <!-- Divider between source and translated text -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="6dp"
            android:background="?attr/colorOutlineVariant" />

        <!-- ======================================================
             Translated text
             ====================================================== -->
        <TextView
            android:id="@+id/textViewTranslatedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorTertiary"
            android:maxLines="2"
            android:ellipsize="end"
            tools:text="Halo, apa kabar?" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>