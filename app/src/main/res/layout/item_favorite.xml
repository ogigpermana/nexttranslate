<?xml version="1.0" encoding="utf-8"?>
<!--
    item_favorite.xml
    Layout for a single favorite translation entry — Gmail inbox style,
    matching item_history.xml design.

    Design:
      - No card elevation; items share one rounded surface container.
      - Top/bottom rounded corners applied programmatically in
        FavoriteAdapter.updateItemShape() based on item position.
      - Full-width divider between items, hidden on last item.

    View ID contract (referenced by FavoriteAdapter.java):
      - rootItemFavorite       : Root clickable container
      - textViewLanguagePair   : Language pair e.g. "EN → ID"
      - textViewTimestamp      : Relative time e.g. "2 hours ago"
      - textViewSourceText     : Original source text (bold)
      - textViewTranslatedText : Translated result (tertiary colour)
      - viewDivider            : Full-width divider, GONE on last item

    Tap root → onItemClick(); swipe left/right → delete via ItemTouchHelper.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootItemFavorite"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/colorSurfaceContainer"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <!-- Content with horizontal padding -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <!-- Top row: language pair + timestamp -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/textViewLanguagePair"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorTertiary"
                android:letterSpacing="0.05"
                tools:text="EN → ID" />

            <!--
                Bookmark filled icon — visual indicator this is a favorite.
                Shown at right of timestamp row.
            -->
            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_bookmark"
                android:layout_marginEnd="6dp"
                app:tint="?attr/colorTertiary"
                android:contentDescription="@null"
                xmlns:app="http://schemas.android.com/apk/res-auto"/>

            <TextView
                android:id="@+id/textViewTimestamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:alpha="0.7"
                tools:text="2 jam lalu" />

        </LinearLayout>

        <!-- Source text — bold, max 2 lines -->
        <TextView
            android:id="@+id/textViewSourceText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurface"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="4dp"
            tools:text="Hello, how are you?" />

        <!-- Translated text — tertiary colour, 1 line -->
        <TextView
            android:id="@+id/textViewTranslatedText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorTertiary"
            android:maxLines="1"
            android:ellipsize="end"
            tools:text="Halo, apa kabar?" />

    </LinearLayout>

    <!--
        Full-width divider between items — Gmail inbox style.
        Hidden on the last item via FavoriteAdapter.updateItemShape().
    -->
    <View
        android:id="@+id/viewDivider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?attr/colorOutlineVariant" />

</LinearLayout>