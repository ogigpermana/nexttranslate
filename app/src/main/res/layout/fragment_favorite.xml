<?xml version="1.0" encoding="utf-8"?>
<!--
    fragment_favorite.xml
    Favorites screen — accessible via the bottom nav Favorite tab.

    Layout structure:
      - Root LinearLayout receives top inset (status bar) via
        ViewCompat.setOnApplyWindowInsetsListener in FavoriteFragment.
      - MaterialToolbar: back navigation (left) + clear-all menu icon (right).
      - Empty state: centred icon + labels, shown when favorites list is empty.
      - RecyclerView: paddingBottom="100dp" clears the bottom navigation bar.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootFavorite"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    tools:context=".presentation.favorite.FavoriteFragment">

    <!--
        Toolbar
        navigationIcon : back arrow — wired in FavoriteFragment.initViews()
        menu           : menu_favorite (clear-all action)
    -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:navigationContentDescription="@string/cd_navigate_back"
        app:title="@string/title_favorite"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        app:menu="@menu/menu_favorite" />

    <!--
        Empty state — shown when favorites list is empty.
        Visibility toggled by FavoriteFragment.initObservers().
    -->
    <LinearLayout
        android:id="@+id/layoutEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        tools:visibility="visible">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_bookmark_border"
            android:alpha="0.3"
            app:tint="?attr/colorOnSurfaceVariant"
            android:contentDescription="@null" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/empty_favorite_title"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:alpha="0.5"
            android:textColor="?attr/colorOnSurface" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/empty_favorite_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:gravity="center"
            android:alpha="0.4"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

    <!--
        Favorites list.
        paddingBottom="100dp" : clears the bottom navigation bar.
        clipToPadding="false" : last item scrolls under the padding area.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewFavorites"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="100dp"
        android:clipToPadding="false"
        android:visibility="gone"
        tools:listitem="@layout/item_favorite"
        tools:visibility="visible" />

</LinearLayout>